# Resend API key (create one at https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=greenchidozie@gmail.com

# Sender address shown on the email.
# Default works immediately and delivers to the Resend account owner's inbox.
# To send from your own domain (e.g. hello@chidoziegreen.com), verify the
# domain in Resend and set it here.
CONTACT_FROM_EMAIL=onboarding@resend.dev
